<% layout("/layouts/boilerplate")  %>
<div class="row mt-3">
    <h1 class="col-6 offset-3">Signup on Wanderlust</h1>
        <div class="col-6 offset-2">
            <form  method="post"   action="/signup" class="needs-validation" novalidate>
                <div class="mb-3">
                    <label for="username" class="form-label">Username</label>
                    <input type="text" 
                       
                        name="username" 
                        class="form-control"
                        required
                    />
                     <div class="valid-feedback">Looks good</div>
                </div>
                   <br>
                <div class="mb-3">
                    <label for="email" class="form-label">Email</label>
                    <input type="text" 
                       
                        name="email" 
                        class="form-control"
                        required
                    />
                     <div class="valid-feedback">fill the image</div>
                </div>
                 <br>
                <div class="mb-3">
                    <label for="password" class="form-label">Password</label>
                    <input type="text" 
                       
                        name="password" 
                        class="form-control"
                        required
                    />
                     <div class="valid-feedback">enter password</div>
                </div>
                <div class="col-8 offset-4">
                     <button class="btn btn-success">Signup</button>
                </div>
                
                    
                






            </form>




    </div>



</div>